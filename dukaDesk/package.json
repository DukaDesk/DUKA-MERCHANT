    "react-dom": "^18.2.0",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0",
