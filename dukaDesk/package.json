{
  "name": "dukadesk-merchant",
  "version": "1.0.0",
  "description": "DukaDesk Merchant Portal - E-commerce Management Dashboard",
  "private": true,
  "homepage": "./",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-keywords": "^5.1.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --watchAll=false",
    "test:watch": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css}\""
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
