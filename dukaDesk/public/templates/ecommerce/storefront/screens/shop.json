{
  "screenId": "shop",
  "title": "Shop",
  "layout": {
    "kind": "scroll",
    "children": [
      {
        "type": "promotion_list",
        "key": "promo-banner",
        "props": {
          "offers": [
            { "title": "New Arrivals", "subtitle": "Up to 30% off", "image": "assets/sale.jpg" }
          ]
        },
        "actions": {
          "tap": { "type": "navigate", "payload": { "push": "/products?filter=new-arrivals" } }
        }
      },
      {
        "type": "category_pills",
        "key": "category-pills",
        "props": {
          "categories": ["All", "Clothing", "Electronics", "Accessories"]
        },
        "actions": {
          "selectCategory": { "type": "filter", "payload": { "source": "category" } }
        }
      },
      {
        "type": "menu_grid",
        "key": "products-grid",
        "props": { "columns": 2 },
        "actions": {
          "addItem": { "type": "add_to_cart" },
          "viewDetails": { "type": "navigate", "payload": { "push": "/product-detail" } }
        }
      }
    ]
  }
}
