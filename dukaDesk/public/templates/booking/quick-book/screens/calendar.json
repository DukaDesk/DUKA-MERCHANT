{
  "screenId": "calendar",
  "title": "Calendar",
  "layout": {
    "kind": "scroll",
    "children": [
      {
        "type": "calendar_strip",
        "key": "date-picker",
        "props": { "minDate": "today", "maxDate": "+30" },
        "actions": { "selectDate": { "type": "filter", "payload": { "source": "date" } } }
      },
      {
        "type": "slot_grid",
        "key": "time-slots",
        "props": { "duration": 30 },
        "actions": { "selectSlot": { "type": "filter", "payload": { "source": "slot" } } }
      }
    ]
  }
}